// components/AddPlayerForm.tsx
"use client";

import { useState } from "react";
import { createClientComponentClient } from "@supabase/auth-helpers-nextjs";
import { Button } from "@/components/ui/button";

export default function AddPlayerForm({ onAdded }: { onAdded: () => void }) {
  const supabase = createClientComponentClient();
  const [nickname, setNickname] = useState("");
  const [game, setGame] = useState("");
  const [loading, setLoading] = useState(false);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);
    const { error } = await supabase.from("players").insert([{ nickname, game }]);
    if (error) alert("Oyuncu eklenemedi: " + error.message);
    else {
      setNickname("");
      setGame("");
      onAdded();
      alert("Oyuncu başarıyla eklendi!");
    }
    setLoading(false);
  };

  return (
    <form onSubmit={handleSubmit} className="flex flex-col gap-3 max-w-md mx-auto mb-10">
      <input
        type="text"
        placeholder="Oyuncu Nickname"
        value={nickname}
        onChange={(e) => setNickname(e.target.value)}
        className="px-4 py-2 rounded-xl bg-gray-800 text-white"
        required
      />
      <input
        type="text"
        placeholder="Oyun"
        value={game}
        onChange={(e) => setGame(e.target.value)}
        className="px-4 py-2 rounded-xl bg-gray-800 text-white"
        required
      />
      <Button type="submit" disabled={loading} className="bg-red-600 hover:bg-red-700 rounded-2xl py-2">
        {loading ? "Ekleniyor..." : "Oyuncu Ekle"}
      </Button>
    </form>
  );
}
// components/AddLeagueForm.tsx
"use client";

import { useState } from "react";
import { createClientComponentClient } from "@supabase/auth-helpers-nextjs";
import { Button } from "@/components/ui/button";

export default function AddLeagueForm({ onAdded }: { onAdded: () => void }) {
  const supabase = createClientComponentClient();
  const [name, setName] = useState("");
  const [type, setType] = useState("Academy");
  const [status, setStatus] = useState("Active");
  const [loading, setLoading] = useState(false);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);
    const { error } = await supabase.from("leagues").insert([{ name, type, status }]);
    if (error) alert("Lig eklenemedi: " + error.message);
    else {
      setName("");
      setType("Academy");
      setStatus("Active");
      onAdded();
      alert("Lig başarıyla eklendi!");
    }
    setLoading(false);
  };

  return (
    <form onSubmit={handleSubmit} className="flex flex-col gap-3 max-w-md mx-auto mb-10">
      <input
        type="text"
        placeholder="Lig Adı"
        value={name}
        onChange={(e) => setName(e.target.value)}
        className="px-4 py-2 rounded-xl bg-gray-800 text-white"
        required
      />
      <select value={type} onChange={(e) => setType(e.target.value)} className="px-4 py-2 rounded-xl bg-gray-800 text-white">
        <option value="Academy">Academy</option>
        <option value="Pro">Pro</option>
        <option value="Open">Open</option>
      </select>
      <select value={status} onChange={(e) => setStatus(e.target.value)} className="px-4 py-2 rounded-xl bg-gray-800 text-white">
        <option value="Active">Active</option>
        <option value="Finished">Finished</option>
      </select>
      <Button type="submit" disabled={loading} className="bg-red-600 hover:bg-red-700 rounded-2xl py-2">
        {loading ? "Ekleniyor..." : "Lig Ekle"}
      </Button>
    </form>
  );
}
